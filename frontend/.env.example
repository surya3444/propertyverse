# Copy to `.env` (same folder) and restart `npm run web` to apply.

# Optional: point the web build at a specific backend.
# API_BASE_URL=http://localhost:5000/api

# Direct browser → Cloudinary uploads (recommended, and required if your machine's
# network blocks the Node backend from reaching Cloudinary). Both are PUBLIC values
# (safe to expose in the browser bundle).
#   1. Cloudinary dashboard → Settings → Upload → "Add upload preset"
#   2. Set "Signing Mode" = Unsigned, save, and copy the preset name below.
#   3. Your cloud name is shown at the top of the dashboard.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Base URL of the public forms web app (new/web). Used to build shareable form
# links shown in the app. Defaults to http://localhost:3001 for local dev.
# FORMS_WEB_URL=http://localhost:3001

# Web push needs NO client config here — the app fetches the backend's public
# VAPID key at runtime. Just set VAPID_* on the backend to enable it.
