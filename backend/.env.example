# Server Configuration
PORT=5000
# Set to `production` on a deployed instance. This makes CORS_ORIGINS mandatory
# (see below) rather than falling back to an allow-all policy.
NODE_ENV=development

# MongoDB Connection String
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/property-verse?retryWrites=true&w=majority

# Google Gemini API Key (free from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin/upgrade the model used for voice extraction.
GEMINI_MODEL=gemini-2.5-flash

# Google Maps Platform key for location autocomplete/geocoding.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# ISO-2 country to bias location results (default: in for India).
GEO_COUNTRY=in

# JWT secret for signing auth tokens. REQUIRED, and must be at least 32 chars —
# the server refuses to boot otherwise. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS: comma-separated allowlist of origins permitted to call the API.
# Leave empty for local dev (permissive). REQUIRED when NODE_ENV=production — a
# missing value fails the boot rather than silently allowing every origin.
# CORS_ORIGINS=https://app.propertyverse.com,https://propertyverse-web.netlify.app
CORS_ORIGINS=

# How often (ms) to sweep overdue scheduled activities into "Missed" (default 5 min).
ACTIVITY_SWEEP_MS=300000

# Cloudinary — hosts property photos & documents. Create a free account at
# cloudinary.com and copy these from the dashboard. Either set the three vars
# below, OR a single CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: folder assets are stored under (default: propertyverse).
CLOUDINARY_FOLDER=propertyverse
# Optional: a private CDN distribution hostname, if you serve assets from one.
# Media URLs submitted through public forms are accepted only when they point at
# res.cloudinary.com (or this host) under CLOUDINARY_CLOUD_NAME.
# CLOUDINARY_CDN_HOST=assets.propertyverse.com

# Web Push (VAPID) — self-hosted browser push for new form responses, no Firebase.
# Our backend sends straight to the browser's push service via the `web-push`
# package. Generate a keypair once with:  npx web-push generate-vapid-keys
# Leave unset to disable web push — the in-app bell/badge still works.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@propertyverse.app

# Native push (OPTIONAL, Android/iOS) via Firebase Cloud Messaging. Only needed
# for the native mobile app — the web app uses VAPID above. Value is the FULL
# service-account JSON on one line. Requires `npm i firebase-admin`.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
