# Server Configuration
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/property-verse?retryWrites=true&w=majority

# Google Gemini API Key (free from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin/upgrade the model used for voice extraction.
GEMINI_MODEL=gemini-2.5-flash

# Google Maps Platform key for location autocomplete/geocoding.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# ISO-2 country to bias location results (default: in for India).
GEO_COUNTRY=in

# JWT secret for signing auth tokens (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS: comma-separated allowlist of origins permitted to call the API.
# Leave empty for local dev (permissive). Set in production, e.g.:
# CORS_ORIGINS=https://app.propertyverse.com,https://propertyverse-1.onrender.com
CORS_ORIGINS=

# How often (ms) to sweep overdue scheduled activities into "Missed" (default 5 min).
ACTIVITY_SWEEP_MS=300000

# Cloudinary — hosts property photos & documents. Create a free account at
# cloudinary.com and copy these from the dashboard. Either set the three vars
# below, OR a single CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: folder assets are stored under (default: propertyverse).
CLOUDINARY_FOLDER=propertyverse

# Push notifications (OPTIONAL). Firebase Cloud Messaging fans out a push for
# each new public form response. Leave unset to disable push — in-app
# notifications (bell/badge) work regardless. Value is the FULL service-account
# JSON on one line (Firebase console → Project settings → Service accounts →
# Generate new private key). Requires `npm i firebase-admin` in the backend.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
